<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_department_esg_tree" model="ir.ui.view">
        <field name="name">hr.department.esg.tree</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <tree string="ESG Departments" default_order="company_id,name" decoration-muted="esg_status == 'inactive'">
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="parent_id" optional="hide"/>
                <field name="manager_id" optional="show"/>
                <field name="esg_manager_id" optional="show"/>
                <field name="esg_employee_count" optional="show"/>
                <field name="environmental_score" optional="show"/>
                <field name="social_score" optional="show"/>
                <field name="governance_score" optional="show"/>
                <field name="total_esg_score" optional="show"/>
                <field name="esg_status" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_department_esg_form" model="ir.ui.view">
        <field name="name">hr.department.esg.form</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <form string="ESG Department">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_esg_employees" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="esg_employee_count" widget="statinfo" string="Employees"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-secondary" invisible="esg_status != 'inactive'"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Department name"/></h1>
                    </div>
                    <group>
                        <group string="Department">
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="manager_id"/>
                            <field name="esg_manager_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                            <field name="esg_status"/>
                        </group>
                        <group string="Latest ESG Scores">
                            <field name="environmental_score" readonly="1"/>
                            <field name="social_score" readonly="1"/>
                            <field name="governance_score" readonly="1"/>
                            <field name="total_esg_score" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employees" name="employees">
                            <field name="member_ids" readonly="1">
                                <tree string="Department Employees">
                                    <field name="name"/>
                                    <field name="job_title" optional="show"/>
                                    <field name="work_email" optional="show"/>
                                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_department_esg_search" model="ir.ui.view">
        <field name="name">hr.department.esg.search</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <search string="Search ESG Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="manager_id"/>
                <field name="esg_manager_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Active ESG" name="esg_active" domain="[('esg_status', '=', 'active')]"/>
                <filter string="Monitoring" name="esg_monitoring" domain="[('esg_status', '=', 'monitoring')]"/>
                <filter string="Inactive ESG" name="esg_inactive" domain="[('esg_status', '=', 'inactive')]"/>
                <separator/>
                <filter string="Has ESG Manager" name="has_esg_manager" domain="[('esg_manager_id', '!=', False)]"/>
                <filter string="Missing ESG Manager" name="missing_esg_manager" domain="[('esg_manager_id', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    <filter string="Parent Department" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    <filter string="ESG Status" name="group_esg_status" context="{'group_by': 'esg_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_department_esg" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_department_esg_search"/>
        <field name="context">{'search_default_esg_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create or configure ESG departments</p>
            <p>Departments provide the organizational structure for ESG ownership, scoring, reporting, and access filtering.</p>
        </field>
    </record>

    <menuitem id="menu_ecosphere_departments"
              name="Departments"
              parent="ecosphere_esg.menu_ecosphere_configuration"
              action="action_hr_department_esg"
              sequence="10"
              groups="ecosphere_esg.group_esg_administrator,ecosphere_esg.group_esg_department_manager"/>
</odoo>
