<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_emission_factor_tree" model="ir.ui.view">
        <field name="name">esg.emission.factor.tree</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <tree string="Emission Factors" default_order="activity_type,scope,name" decoration-muted="not active">
                <field name="name"/>
                <field name="code"/>
                <field name="activity_type"/>
                <field name="scope"/>
                <field name="factor_value"/>
                <field name="input_unit"/>
                <field name="output_unit"/>
                <field name="region" optional="show"/>
                <field name="applicable_year" optional="show"/>
                <field name="valid_from" optional="hide"/>
                <field name="valid_to" optional="hide"/>
                <field name="category_id" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="active" widget="boolean_toggle" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_emission_factor_form" model="ir.ui.view">
        <field name="name">esg.emission.factor.form</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <form string="Emission Factor">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-secondary" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Emission factor name"/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="code"/>
                            <field name="activity_type"/>
                            <field name="scope"/>
                            <field name="category_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group string="Factor">
                            <field name="factor_value"/>
                            <field name="input_unit"/>
                            <field name="output_unit"/>
                            <field name="region"/>
                            <field name="applicable_year"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Validity" name="validity">
                            <group>
                                <field name="valid_from"/>
                                <field name="valid_to"/>
                            </group>
                        </page>
                        <page string="Source" name="source">
                            <group>
                                <field name="source"/>
                                <field name="source_url"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_esg_emission_factor_search" model="ir.ui.view">
        <field name="name">esg.emission.factor.search</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <search string="Search Emission Factors">
                <field name="name"/>
                <field name="code"/>
                <field name="activity_type"/>
                <field name="scope"/>
                <field name="category_id"/>
                <field name="region"/>
                <field name="applicable_year"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Scope 1" name="scope_1" domain="[('scope', '=', 'scope_1')]"/>
                <filter string="Scope 2" name="scope_2" domain="[('scope', '=', 'scope_2')]"/>
                <filter string="Scope 3" name="scope_3" domain="[('scope', '=', 'scope_3')]"/>
                <group expand="0" string="Group By">
                    <filter string="Activity Type" name="group_activity_type" context="{'group_by': 'activity_type'}"/>
                    <filter string="Scope" name="group_scope" context="{'group_by': 'scope'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_esg_emission_factor" model="ir.actions.act_window">
        <field name="name">Emission Factors</field>
        <field name="res_model">esg.emission.factor</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_esg_emission_factor_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an emission factor</p>
            <p>Emission factors convert activity data such as fuel, electricity, distance, purchases, and waste into kgCO2e.</p>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_tree" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.tree</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <tree string="Carbon Transactions" default_order="date desc,reference desc" decoration-success="state == 'validated'" decoration-muted="state == 'cancelled'">
                <field name="reference"/>
                <field name="date"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="source_type"/>
                <field name="emission_factor_id"/>
                <field name="scope"/>
                <field name="activity_value"/>
                <field name="activity_unit" optional="show"/>
                <field name="emission_kgco2e" sum="Total kgCO2e"/>
                <field name="calculation_method" optional="show"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_form" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.form</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <form string="Carbon Transaction">
                <header>
                    <button name="action_calculate" type="object" string="Calculate" class="btn-primary" invisible="state not in ('draft', 'calculated')"/>
                    <button name="action_validate" type="object" string="Validate" class="btn-primary" invisible="state != 'calculated'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('cancelled', 'validated')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,calculated,validated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_source_record" type="object" class="oe_stat_button" icon="fa-external-link" invisible="not source_model or not source_res_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Source</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-secondary" invisible="state != 'cancelled'"/>
                    <div class="oe_title">
                        <label for="reference"/>
                        <h1><field name="reference" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Context">
                            <field name="date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="department_id"/>
                            <field name="employee_id"/>
                            <field name="source_type"/>
                            <field name="calculation_method"/>
                        </group>
                        <group string="Calculated Result">
                            <field name="scope" readonly="1"/>
                            <field name="category_id" readonly="1"/>
                            <field name="emission_kgco2e" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Calculation" name="calculation">
                            <group>
                                <group string="Activity Data">
                                    <field name="activity_value"/>
                                    <field name="activity_unit"/>
                                    <field name="conversion_multiplier"/>
                                </group>
                                <group string="Emission Factor">
                                    <field name="emission_factor_id"/>
                                </group>
                            </group>
                            <group string="Equation Explanation">
                                <field name="calculation_details" readonly="1" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Source Identity" name="source_identity" groups="ecosphere_esg.group_esg_officer,ecosphere_esg.group_esg_administrator">
                            <group>
                                <field name="source_model"/>
                                <field name="source_res_id"/>
                                <field name="source_line_reference"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes or validation comments."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_search" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.search</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Carbon Transactions">
                <field name="reference"/>
                <field name="date"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="source_type"/>
                <field name="emission_factor_id"/>
                <field name="scope"/>
                <field name="category_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Calculated" name="state_calculated" domain="[('state', '=', 'calculated')]"/>
                <filter string="Validated" name="state_validated" domain="[('state', '=', 'validated')]"/>
                <filter string="Automatic" name="automatic" domain="[('calculation_method', '=', 'automatic')]"/>
                <filter string="Manual" name="manual" domain="[('calculation_method', '=', 'manual')]"/>
                <separator/>
                <filter string="Scope 1" name="scope_1" domain="[('scope', '=', 'scope_1')]"/>
                <filter string="Scope 2" name="scope_2" domain="[('scope', '=', 'scope_2')]"/>
                <filter string="Scope 3" name="scope_3" domain="[('scope', '=', 'scope_3')]"/>
                <group expand="0" string="Group By">
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Scope" name="group_scope" context="{'group_by': 'scope'}"/>
                    <filter string="Source Type" name="group_source_type" context="{'group_by': 'source_type'}"/>
                    <filter string="Emission Factor" name="group_emission_factor" context="{'group_by': 'emission_factor_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_graph" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.graph</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <graph string="Carbon Emissions" type="bar" sample="0">
                <field name="date" interval="month"/>
                <field name="emission_kgco2e" type="measure"/>
                <field name="scope"/>
            </graph>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_pivot" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.pivot</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <pivot string="Carbon Emissions" sample="0">
                <field name="date" interval="month" type="row"/>
                <field name="scope" type="col"/>
                <field name="emission_kgco2e" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_esg_carbon_transaction" model="ir.actions.act_window">
        <field name="name">Carbon Transactions</field>
        <field name="res_model">esg.carbon.transaction</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_esg_carbon_transaction_search"/>
        <field name="context">{'search_default_state_validated': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a carbon transaction</p>
            <p>Carbon transactions store auditable emissions calculated from activity data, emission factors, and conversion multipliers.</p>
        </field>
    </record>

    <record id="view_esg_environmental_goal_tree" model="ir.ui.view">
        <field name="name">esg.environmental.goal.tree</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <tree string="Environmental Goals" default_order="target_date,name" decoration-success="status == 'achieved'" decoration-danger="status == 'missed'" decoration-muted="status == 'cancelled'">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="metric_type"/>
                <field name="goal_direction"/>
                <field name="baseline_value" optional="show"/>
                <field name="target_value" optional="show"/>
                <field name="current_value" optional="show"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="target_date"/>
                <field name="owner_id" optional="show"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_environmental_goal_form" model="ir.ui.view">
        <field name="name">esg.environmental.goal.form</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <form string="Environmental Goal">
                <header>
                    <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_mark_achieved" type="object" string="Mark Achieved" class="btn-primary" invisible="status not in ('active', 'missed')"/>
                    <button name="action_mark_missed" type="object" string="Mark Missed" invisible="status != 'active'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="status in ('achieved', 'cancelled')"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,achieved"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Missed" bg_color="text-bg-danger" invisible="status != 'missed'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-secondary" invisible="status != 'cancelled'"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Environmental goal"/></h1>
                    </div>
                    <group>
                        <group string="Ownership">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="department_id"/>
                            <field name="owner_id"/>
                        </group>
                        <group string="Progress">
                            <field name="progress_percentage" widget="progressbar" readonly="1"/>
                            <field name="target_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Metric">
                            <field name="metric_type"/>
                            <field name="goal_direction"/>
                            <field name="baseline_year"/>
                        </group>
                        <group string="Values">
                            <field name="baseline_value"/>
                            <field name="target_value"/>
                            <field name="current_value"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the goal, measurement source, and review process."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_esg_environmental_goal_search" model="ir.ui.view">
        <field name="name">esg.environmental.goal.search</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <search string="Search Environmental Goals">
                <field name="name"/>
                <field name="department_id"/>
                <field name="owner_id"/>
                <field name="metric_type"/>
                <field name="status"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Active" name="active_goals" domain="[('status', '=', 'active')]"/>
                <filter string="Achieved" name="achieved" domain="[('status', '=', 'achieved')]"/>
                <filter string="Missed" name="missed" domain="[('status', '=', 'missed')]"/>
                <filter string="At Risk" name="at_risk" domain="[('status', '=', 'active'), ('progress_percentage', '&lt;', 50)]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Metric" name="group_metric" context="{'group_by': 'metric_type'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Target Month" name="group_target_month" context="{'group_by': 'target_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_esg_environmental_goal" model="ir.actions.act_window">
        <field name="name">Environmental Goals</field>
        <field name="res_model">esg.environmental.goal</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_esg_environmental_goal_search"/>
        <field name="context">{'search_default_active_goals': 1}</field>
    </record>

    <record id="product_template_form_view_esg" model="ir.ui.view">
        <field name="name">product.template.form.esg</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ESG" name="esg_profile">
                    <group>
                        <group string="Carbon Profile">
                            <field name="esg_category_id"/>
                            <field name="esg_emission_factor_id"/>
                            <field name="esg_carbon_value_per_unit"/>
                        </group>
                        <group string="Material Profile">
                            <field name="esg_recycled_percentage"/>
                            <field name="esg_renewable_material_percentage"/>
                            <field name="esg_recyclable"/>
                            <field name="esg_supplier_sustainability_rating"/>
                        </group>
                    </group>
                    <field name="esg_notes" placeholder="Supplier ESG notes, product sustainability assumptions, or calculation references."/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_product_esg_profiles" model="ir.actions.act_window">
        <field name="name">Product ESG Profiles</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('esg_emission_factor_id', '!=', False)]</field>
        <field name="context">{'search_default_filter_to_purchase': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Configure product ESG profiles</p>
            <p>Assign emission factors and material sustainability attributes to products used in purchasing and manufacturing calculations.</p>
        </field>
    </record>

    <record id="action_esg_environmental_analysis" model="ir.actions.act_window">
        <field name="name">Environmental Analysis</field>
        <field name="res_model">esg.carbon.transaction</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_esg_carbon_transaction_search"/>
        <field name="context">{'search_default_state_validated': 1, 'search_default_group_month': 1}</field>
    </record>

    <menuitem id="menu_esg_carbon_transactions"
              name="Carbon Transactions"
              parent="ecosphere_esg.menu_ecosphere_environmental"
              action="action_esg_carbon_transaction"
              sequence="10"/>

    <menuitem id="menu_esg_emission_factors"
              name="Emission Factors"
              parent="ecosphere_esg.menu_ecosphere_environmental"
              action="action_esg_emission_factor"
              sequence="20"/>

    <menuitem id="menu_esg_product_profiles"
              name="Product ESG Profiles"
              parent="ecosphere_esg.menu_ecosphere_environmental"
              action="action_product_esg_profiles"
              sequence="30"/>

    <menuitem id="menu_esg_environmental_goals"
              name="Environmental Goals"
              parent="ecosphere_esg.menu_ecosphere_environmental"
              action="action_esg_environmental_goal"
              sequence="40"/>

    <menuitem id="menu_esg_environmental_analysis"
              name="Environmental Analysis"
              parent="ecosphere_esg.menu_ecosphere_environmental"
              action="action_esg_environmental_analysis"
              sequence="50"/>
</odoo>
