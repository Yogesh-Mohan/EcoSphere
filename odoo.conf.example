[options]
; Copy this file to odoo.conf and adjust paths for your machine.

; PostgreSQL connection
db_host = localhost
db_port = 5432
db_user = odoo
db_password = odoo
dbfilter = .*

; Local addons paths. Keep the EcoSphere custom addon path first or included.
addons_path = /opt/odoo/odoo/addons,/opt/odoo/custom/addons

; Server
http_port = 8069
proxy_mode = False
workers = 0
limit_time_cpu = 120
limit_time_real = 240

; Logging
logfile = /var/log/odoo/odoo.log
log_level = info

; Demo/development convenience
without_demo = False
list_db = True
