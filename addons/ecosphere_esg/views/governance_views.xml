<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_policy_kanban" model="ir.ui.view">
        <field name="name">ecosphere.esg.policy.kanban</field>
        <field name="model">ecosphere.esg.policy</field>
        <field name="arch" type="xml"><kanban default_group_by="state"><field name="name"/><field name="policy_code"/><field name="version"/><templates><t t-name="card"><div><strong><field name="name"/></strong><div><field name="policy_code"/> v<field name="version"/></div></div></t></templates></kanban></field>
    </record>
    <record id="view_esg_policy_list" model="ir.ui.view">
        <field name="name">ecosphere.esg.policy.list</field>
        <field name="model">ecosphere.esg.policy</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="policy_code"/><field name="version"/><field name="owner_id"/><field name="effective_date"/><field name="review_date"/><field name="state"/></list></field>
    </record>
    <record id="view_esg_policy_form" model="ir.ui.view">
        <field name="name">ecosphere.esg.policy.form</field>
        <field name="model">ecosphere.esg.policy</field>
        <field name="arch" type="xml">
            <form>
                <header><button name="action_publish" type="object" string="Publish" class="btn-primary"/><button name="action_expire" type="object" string="Expire"/><button name="action_archive" type="object" string="Archive"/><field name="state" widget="statusbar"/></header>
                <sheet><group><group><field name="name"/><field name="policy_code"/><field name="version"/><field name="category_id"/><field name="owner_id"/></group><group><field name="publish_date"/><field name="effective_date"/><field name="review_date"/><field name="attachment" filename="attachment_filename"/><field name="attachment_filename"/></group></group><group><field name="applicable_department_ids" widget="many2many_tags"/><field name="applicable_employee_ids" widget="many2many_tags"/></group><field name="description"/></sheet>
                <div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div>
            </form>
        </field>
    </record>

    <record id="view_policy_ack_list" model="ir.ui.view"><field name="name">ecosphere.policy.acknowledgement.list</field><field name="model">ecosphere.policy.acknowledgement</field><field name="arch" type="xml"><list><field name="policy_id"/><field name="employee_id"/><field name="policy_version"/><field name="assigned_date"/><field name="acknowledgement_date"/><field name="status"/></list></field></record>
    <record id="view_policy_ack_form" model="ir.ui.view"><field name="name">ecosphere.policy.acknowledgement.form</field><field name="model">ecosphere.policy.acknowledgement</field><field name="arch" type="xml"><form><header><button name="action_acknowledge" type="object" string="Acknowledge" class="btn-primary"/><field name="status" widget="statusbar"/></header><sheet><group><field name="policy_id"/><field name="employee_id"/><field name="policy_version"/><field name="assigned_date"/><field name="acknowledgement_date"/><field name="employee_confirmation"/></group></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>
    <record id="view_policy_ack_pivot" model="ir.ui.view"><field name="name">ecosphere.policy.acknowledgement.pivot</field><field name="model">ecosphere.policy.acknowledgement</field><field name="arch" type="xml"><pivot><field name="policy_id" type="row"/><field name="status" type="col"/></pivot></field></record>
    <record id="view_policy_ack_graph" model="ir.ui.view"><field name="name">ecosphere.policy.acknowledgement.graph</field><field name="model">ecosphere.policy.acknowledgement</field><field name="arch" type="xml"><graph><field name="policy_id"/><field name="status"/></graph></field></record>

    <record id="view_audit_calendar" model="ir.ui.view"><field name="name">ecosphere.audit.calendar</field><field name="model">ecosphere.audit</field><field name="arch" type="xml"><calendar date_start="start_date" date_stop="end_date" color="audit_type"><field name="name"/><field name="department_id"/><field name="status"/></calendar></field></record>
    <record id="view_audit_kanban" model="ir.ui.view"><field name="name">ecosphere.audit.kanban</field><field name="model">ecosphere.audit</field><field name="arch" type="xml"><kanban default_group_by="status"><field name="name"/><field name="audit_type"/><templates><t t-name="card"><div><strong><field name="name"/></strong><div><field name="audit_type"/></div></div></t></templates></kanban></field></record>
    <record id="view_audit_list" model="ir.ui.view"><field name="name">ecosphere.audit.list</field><field name="model">ecosphere.audit</field><field name="arch" type="xml"><list><field name="name"/><field name="audit_type"/><field name="auditor_id"/><field name="department_id"/><field name="start_date"/><field name="end_date"/><field name="status"/></list></field></record>
    <record id="view_audit_form" model="ir.ui.view"><field name="name">ecosphere.audit.form</field><field name="model">ecosphere.audit</field><field name="arch" type="xml"><form><sheet><group><group><field name="name"/><field name="audit_type"/><field name="auditor_id"/><field name="department_id"/></group><group><field name="start_date"/><field name="end_date"/><field name="status"/><field name="evidence_attachment" filename="evidence_filename"/><field name="evidence_filename"/></group></group><field name="scope"/><field name="description"/><field name="result"/></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>

    <record id="view_compliance_issue_kanban" model="ir.ui.view"><field name="name">ecosphere.compliance.issue.kanban</field><field name="model">ecosphere.compliance.issue</field><field name="arch" type="xml"><kanban default_group_by="status"><field name="name"/><field name="severity"/><field name="is_overdue"/><templates><t t-name="card"><div><strong><field name="name"/></strong><div><field name="severity"/></div><div><field name="due_date"/></div></div></t></templates></kanban></field></record>
    <record id="view_compliance_issue_list" model="ir.ui.view"><field name="name">ecosphere.compliance.issue.list</field><field name="model">ecosphere.compliance.issue</field><field name="arch" type="xml"><list decoration-danger="is_overdue"><field name="name"/><field name="department_id"/><field name="severity"/><field name="owner_id"/><field name="raised_date"/><field name="due_date"/><field name="is_overdue"/><field name="status"/></list></field></record>
    <record id="view_compliance_issue_form" model="ir.ui.view"><field name="name">ecosphere.compliance.issue.form</field><field name="model">ecosphere.compliance.issue</field><field name="arch" type="xml"><form><header><button name="action_start" type="object" string="Start"/><button name="action_resolve" type="object" string="Resolve"/><button name="action_verify" type="object" string="Verify" groups="ecosphere_esg.group_esg_auditor,ecosphere_esg.group_esg_manager"/><button name="action_close" type="object" string="Close" groups="ecosphere_esg.group_esg_auditor,ecosphere_esg.group_esg_manager"/><field name="status" widget="statusbar"/></header><sheet><group><group><field name="name"/><field name="audit_id"/><field name="department_id"/><field name="severity"/><field name="owner_id"/></group><group><field name="raised_date"/><field name="due_date"/><field name="is_overdue"/><field name="resolution_date"/><field name="verified_by_id"/></group></group><field name="description"/><field name="corrective_action"/><field name="evidence" filename="evidence_filename"/><field name="evidence_filename"/></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>
    <record id="view_compliance_issue_pivot" model="ir.ui.view"><field name="name">ecosphere.compliance.issue.pivot</field><field name="model">ecosphere.compliance.issue</field><field name="arch" type="xml"><pivot><field name="department_id" type="row"/><field name="severity" type="col"/></pivot></field></record>
    <record id="view_compliance_issue_graph" model="ir.ui.view"><field name="name">ecosphere.compliance.issue.graph</field><field name="model">ecosphere.compliance.issue</field><field name="arch" type="xml"><graph><field name="department_id"/><field name="severity"/></graph></field></record>
</odoo>
