<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_badge_list" model="ir.ui.view"><field name="name">ecosphere.badge.list</field><field name="model">ecosphere.badge</field><field name="arch" type="xml"><list><field name="name"/><field name="metric"/><field name="operator"/><field name="threshold"/><field name="active"/></list></field></record>
    <record id="view_badge_form" model="ir.ui.view"><field name="name">ecosphere.badge.form</field><field name="model">ecosphere.badge</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="description"/><field name="icon"/><field name="metric"/><field name="operator"/><field name="threshold"/><field name="active"/></group></sheet></form></field></record>
    <record id="view_reward_kanban" model="ir.ui.view"><field name="name">ecosphere.reward.kanban</field><field name="model">ecosphere.reward</field><field name="arch" type="xml"><kanban><field name="name"/><field name="points_required"/><field name="available_stock"/><templates><t t-name="card"><div><strong><field name="name"/></strong><div><field name="points_required"/> points</div><div>Stock: <field name="available_stock"/></div></div></t></templates></kanban></field></record>
    <record id="view_reward_list" model="ir.ui.view"><field name="name">ecosphere.reward.list</field><field name="model">ecosphere.reward</field><field name="arch" type="xml"><list><field name="name"/><field name="points_required"/><field name="available_stock"/><field name="company_id"/><field name="active"/></list></field></record>
    <record id="view_reward_form" model="ir.ui.view"><field name="name">ecosphere.reward.form</field><field name="model">ecosphere.reward</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="description"/><field name="image"/><field name="points_required"/><field name="available_stock"/><field name="company_id"/><field name="active"/></group></sheet></form></field></record>
    <record id="view_points_transaction_list" model="ir.ui.view"><field name="name">ecosphere.points.transaction.list</field><field name="model">ecosphere.points.transaction</field><field name="arch" type="xml"><list><field name="name"/><field name="employee_id"/><field name="department_id"/><field name="date"/><field name="points"/><field name="reason"/><field name="state"/></list></field></record>
    <record id="view_points_transaction_form" model="ir.ui.view"><field name="name">ecosphere.points.transaction.form</field><field name="model">ecosphere.points.transaction</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="employee_id"/><field name="department_id"/><field name="date"/><field name="points"/><field name="reason"/><field name="source_model"/><field name="source_record_id"/><field name="state"/></group></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="message_ids"/></div></form></field></record>
    <record id="view_points_transaction_pivot" model="ir.ui.view"><field name="name">ecosphere.points.transaction.pivot</field><field name="model">ecosphere.points.transaction</field><field name="arch" type="xml"><pivot><field name="department_id" type="row"/><field name="employee_id" type="row"/><field name="points" type="measure"/></pivot></field></record>
    <record id="view_points_transaction_graph" model="ir.ui.view"><field name="name">ecosphere.points.transaction.graph</field><field name="model">ecosphere.points.transaction</field><field name="arch" type="xml"><graph><field name="department_id"/><field name="points" type="measure"/></graph></field></record>
    <record id="view_employee_badge_list" model="ir.ui.view"><field name="name">ecosphere.employee.badge.list</field><field name="model">ecosphere.employee.badge</field><field name="arch" type="xml"><list><field name="employee_id"/><field name="badge_id"/><field name="awarded_date"/><field name="source_note"/></list></field></record>
    <record id="view_reward_redemption_list" model="ir.ui.view"><field name="name">ecosphere.reward.redemption.list</field><field name="model">ecosphere.reward.redemption</field><field name="arch" type="xml"><list><field name="name"/><field name="employee_id"/><field name="reward_id"/><field name="points_required"/><field name="request_date"/><field name="state"/></list></field></record>
    <record id="view_reward_redemption_form" model="ir.ui.view"><field name="name">ecosphere.reward.redemption.form</field><field name="model">ecosphere.reward.redemption</field><field name="arch" type="xml"><form><header><button name="action_approve" type="object" string="Approve" groups="ecosphere_esg.group_esg_manager"/><button name="action_fulfill" type="object" string="Fulfill" groups="ecosphere_esg.group_esg_manager"/><button name="action_reject" type="object" string="Reject" groups="ecosphere_esg.group_esg_manager"/><button name="action_cancel" type="object" string="Cancel"/><field name="state" widget="statusbar"/></header><sheet><group><field name="name"/><field name="employee_id"/><field name="reward_id"/><field name="points_required"/><field name="request_date"/><field name="approved_by_id"/><field name="points_transaction_id"/></group></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>
</odoo>
