<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_compliance_issue" model="mail.template">
        <field name="name">EcoSphere Compliance Issue Notification</field>
        <field name="model_id" ref="model_ecosphere_compliance_issue"/>
        <field name="subject">EcoSphere compliance issue: {{ object.name }}</field>
        <field name="email_from">{{ user.email_formatted }}</field>
        <field name="email_to">{{ object.owner_id.email_formatted }}</field>
        <field name="body_html" type="html">
            <div>
                <p>A compliance issue has been assigned.</p>
                <p><strong>Severity:</strong> <t t-out="object.severity"/></p>
                <p><strong>Due date:</strong> <t t-out="object.due_date"/></p>
            </div>
        </field>
    </record>
    <record id="email_template_policy_reminder" model="mail.template">
        <field name="name">EcoSphere Policy Reminder</field>
        <field name="model_id" ref="model_ecosphere_policy_acknowledgement"/>
        <field name="subject">Policy acknowledgement reminder: {{ object.policy_id.name }}</field>
        <field name="email_from">{{ user.email_formatted }}</field>
        <field name="email_to">{{ object.employee_id.work_email }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Please acknowledge policy <strong><t t-out="object.policy_id.name"/></strong>.</p>
            </div>
        </field>
    </record>
</odoo>
