<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_esg_summary" model="ir.actions.report">
        <field name="name">ESG Summary Report</field>
        <field name="model">ecosphere.department.score</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecosphere_esg.report_esg_summary</field>
        <field name="report_file">ecosphere_esg.report_esg_summary</field>
        <field name="binding_model_id" ref="model_ecosphere_department_score"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_esg_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>EcoSphere ESG Summary</h2>
                        <p><strong>Department:</strong> <span t-field="doc.department_id"/></p>
                        <p><strong>Period:</strong> <span t-field="doc.period"/></p>
                        <table class="table table-sm">
                            <tr><th>Environmental</th><td><span t-field="doc.environmental_score"/></td></tr>
                            <tr><th>Social</th><td><span t-field="doc.social_score"/></td></tr>
                            <tr><th>Governance</th><td><span t-field="doc.governance_score"/></td></tr>
                            <tr><th>Total</th><td><span t-field="doc.total_score"/></td></tr>
                        </table>
                        <h3>Score Explanation</h3>
                        <p t-field="doc.calculation_details"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
